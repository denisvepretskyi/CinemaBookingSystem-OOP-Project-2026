<Window x:Class="CinemaBookingSystem.UI.Windows.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AdminWindow" Height="600" Width="1000" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF919BB5" Offset="0"/>
                <GradientStop Color="#FF14275B" Offset="1"/>
                <GradientStop Color="#FF7B89B1" Offset="0.46"/>
                <GradientStop Color="#FF002580" Offset="0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Задаємо 2 колонки: перша для меню (фіксована), друга для контенту (тягнеться) -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛІВЕ МЕНЮ -->
        <Border Grid.Column="0" CornerRadius="20" Margin="20" Background="#FFC4CFED">
            <StackPanel Margin="0,20,0,0">
                <Button Height="45" Margin="15, 10" BorderThickness="0" Background="#4A69BD" Cursor="Hand" Click="NavMovies_Click">
                    <TextBlock Text="Фільми" Foreground="White" FontWeight="SemiBold" FontSize="16"/>
                </Button>

                <Button Height="45" Margin="15, 0, 15, 10" BorderThickness="0" Background="#4A69BD" Cursor="Hand" Click="NavSessions_Click">
                    <TextBlock Text="Сеанси" Foreground="White" FontWeight="SemiBold" FontSize="16"/>
                </Button>

                <Button Height="45" Margin="15, 0, 15, 10" BorderThickness="0" Background="#4A69BD" Cursor="Hand" Click="NavStats_Click">
                    <TextBlock Text="Статистика" Foreground="White" FontWeight="SemiBold" FontSize="16"/>
                </Button>

                <Button Height="45" Margin="15, 0, 15, 10" BorderThickness="0" Background="#FFC15F5C" Cursor="Hand" Click="Logout_Click">
                    <TextBlock Text="Вихід" Foreground="White" FontWeight="SemiBold" FontSize="16"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- ПРАВА ЧАСТИНА (Контент) -->
        <Border Grid.Column="1" CornerRadius="20" Margin="0,20,20,20" Background="#FFCDDAF3">
            <!-- Frame, в який ми будемо завантажувати наші сторінки -->
            <Frame x:Name="AdminContentFrame" NavigationUIVisibility="Hidden" Margin="10"/>
        </Border>
    </Grid>
</Window>
