<Window x:Class="CinemaBookingSystem.UI.Windows.MovieEditWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Дані фільму" Height="670" Width="750" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">


        <StackPanel>
            <TextBlock  Text="Назва" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,0,0,5"/>

            <TextBox x:Name="TitleTextBox"  Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Height="40" Margin="0,0,0,15" Padding="5"/>

            <TextBlock  Text="Режисер" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,0,0,5"/>
            <TextBox x:Name="DirectorTextBox" Text="{Binding Director, UpdateSourceTrigger=PropertyChanged}" Height="40" Margin="0,0,0,15" Padding="5"/>

            <TextBlock Text="Тривалість (хв)" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,0,0,5"/>
            <TextBox x:Name="DurationTextBox" Text="{Binding Duration, UpdateSourceTrigger=PropertyChanged}" Height="40" Margin="0,0,0,15" Padding="5"/>

            <TextBlock  Text="Жанри" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,0,0,5"/>
            <ListBox x:Name="GenresListBox" Height="100" Margin="0,0,0,20" SelectionMode="Multiple" BorderBrush="#DDDDDD">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding}" 
                      IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" 
                      Margin="0,2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock  Text="Опис" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Height="40" Margin="0,0,0,15" Padding="5"/>

            <TextBlock  Text="Постер (URL)" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,0,0,5"/>
            <TextBox x:Name="PosterPathTextBox" Text="{Binding PosterPath, UpdateSourceTrigger=PropertyChanged}" Height="40" Margin="0,0,0,15" Padding="5"/>

        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="10" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Скасувати" Width="100" Height="35" Margin="0,0,10,0" Background="#FFD9534F" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Cancel_Click"/>
            <Button Content="Зберегти" Width="100" Height="35" Background="#4A69BD" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
