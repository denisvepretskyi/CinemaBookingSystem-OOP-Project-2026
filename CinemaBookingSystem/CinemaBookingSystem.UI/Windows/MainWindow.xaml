<Window x:Class="CinemaBookingSystem.UI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CinemaBookingSystem.UI.Windows"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF919BB5" Offset="0"/>
                <GradientStop Color="#FF14275B" Offset="1"/>
                <GradientStop Color="#FF7B89B1" Offset="0.46"/>
                <GradientStop Color="#FF002580" Offset="0"/>
            </LinearGradientBrush>
        </Grid.Background>


        <Grid x:Name="TopMenu" Margin="60,23,120,0" VerticalAlignment="Top">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBox x:Name="SearchTextBox" 
                     Height="37" Margin ="0" Background="#FFE1E0F7" BorderThickness="0"
                     VerticalAlignment="Center" TextChanged="SearchTextBox_TextChanged"/>

                <TextBlock Text="Пошук" Foreground="#A0A0A0" FontSize="14"
                       VerticalAlignment="Center" HorizontalAlignment="Left" 
                       Margin="21,0,0,0" IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Hidden"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <Button x:Name="FiltresButton" Grid.Column="1" VerticalAlignment="Center"
                Width="59" Height="59" Background="Transparent" BorderThickness="0" 
                Cursor="Hand" Click="FilterButton_Click" Margin="15,0,0,0">

                <Image Source="pack://application:,,,/Images/FiltresButton.png" 
                   Stretch="Uniform" Margin="8" RenderOptions.BitmapScalingMode="HighQuality"/>

                <Button.ContextMenu>
                    <ContextMenu x:Name="GenreContextMenu" Placement="Bottom"></ContextMenu>
                </Button.ContextMenu>
            </Button>

            <Grid Grid.Column="2" Margin="40,0,0,0" VerticalAlignment="Center">
                <ComboBox x:Name="CinemaComboBox" 
                      Width="220" Height="35" VerticalAlignment="Center"
                      Cursor="Hand" FontSize="14" FontFamily="Century Gothic"
                      DisplayMemberPath="Name" 
                      SelectionChanged="CinemaComboBox_SelectionChanged">
                </ComboBox>

                <TextBlock x:Name="CinemaPlaceholder" 
                       Text="Обрати кінотеатр" 
                       Foreground="#A0A0A0" FontSize="14" FontFamily="Century Gothic"
                       VerticalAlignment="Center" HorizontalAlignment="Left" 
                       Margin="10,0,0,0" IsHitTestVisible="False"/>
            </Grid> 
        </Grid>
      

            <Button x:Name="GlobalBackButton"
            Panel.ZIndex="99"
            Width="40" Height="40" 
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="35,30,0,0" 
            Background="Transparent" BorderThickness="0" 
            Cursor="Hand" Click="GlobalBackButton_Click">
                <Image Source="pack://application:,,,/Images/BackButton.png" 
               Stretch="Uniform" Margin="8"
               RenderOptions.BitmapScalingMode="HighQuality"/>
            </Button>

            <Button x:Name="ProfileButton" 
            Panel.ZIndex="99"
            Width="59" Height="59" 
            VerticalAlignment="Top"
            HorizontalAlignment="Right" 
            Margin="0,20,40,0"
            Background="Transparent" BorderThickness="0" 
            Cursor="Hand" Click="ProfileButton_Click">
                <Image Source="pack://application:,,,/Images/MyProfileButton.png" 
               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" Height="41" Width="39"/>
            </Button>


        <Frame x:Name="MainFrame" 
            NavigationUIVisibility="Hidden" 
            Navigated="MainFrame_Navigated"/>
        
    </Grid> 
</Window>
