<Window x:Class="CinemaBookingSystem.UI.Windows.SessionEditWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Дані фільму" Height="670" Width="750" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="20">


        <StackPanel>
            <TextBlock Text="Фільм:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="MovieComboBox" Height="30" Margin="0,0,0,15" Cursor="Hand"
                  DisplayMemberPath="Title" SelectedValuePath="Id"/>

            <TextBlock Text="Кінотеатр:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox  x:Name="CinemaComboBox" Height="30" Margin="0,0,0,15" Cursor="Hand"
      DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="CinemaComboBox_SelectionChanged"/>

            <TextBlock Text="Зал:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox  x:Name="HallComboBox" Height="30" Margin="0,0,0,15" Cursor="Hand"
                  DisplayMemberPath="Name" SelectedValuePath="Id"/>            

            <Grid Grid.Row="4" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Дата сеансу:" FontWeight="Bold" Margin="0,0,0,5"/>
                    <!-- Календарик -->
                    <DatePicker x:Name="SessionDatePicker" Height="40" Cursor="Hand"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Час (ГГ:ХХ):" FontWeight="Bold" Margin="0,0,0,5"/>
                    <!-- Текстове поле для часу -->
                    <TextBox x:Name="TimeTextBox" Height="40" Padding="5" ToolTip="Введіть час у форматі 14:30"/>
                </StackPanel>
            </Grid>

            <TextBlock  Text="Ціна квитка:" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5,0,0,5"/>
            <TextBox x:Name="PriceTextBox" Height="40" Margin="0,0,0,15" Padding="5"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Скасувати" Width="100" Height="35" Margin="0,0,10,0" Background="#FFD9534F" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Cancel_Click"/>
            <Button Content="Зберегти" Width="100" Height="35" Background="#4A69BD" Foreground="White" BorderThickness="0" Cursor="Hand" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
