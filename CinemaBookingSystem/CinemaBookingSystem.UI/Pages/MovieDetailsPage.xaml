<Page x:Class="CinemaBookingSystem.UI.Pages.MovieDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaBookingSystem.UI.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MovieDetailsPage">


    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="40, 100, 20, 40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Top">
                    
                    <Border Background="#BDBDBD" 
                        CornerRadius="20" 
                        Width="280" Height="360"
                        ClipToBounds="True">
                        <Image Source="{Binding PosterPath}" Stretch="UniformToFill" />
                    </Border>

                    <Border Background="#D6E0F5" 
                        CornerRadius="20" 
                        Width="280" Height="200" 
                        Margin="0,20,0,0">
                        <StackPanel Margin="20">

                            <TextBlock FontSize="19" Margin="0,0,10,10" TextWrapping="Wrap">
                            <Run Text="Режисер: " FontWeight="Bold"/>            
                            <Run Text="{Binding Director, StringFormat='{}{0}'}" FontFamily="Century Gothic"/>
                            </TextBlock>

                            <TextBlock FontSize="19" Margin="0,0,10,10" TextWrapping="Wrap">
                            <Run Text="Тривалість: " FontWeight="Bold" />            
                            <Run Text="{Binding Duration, StringFormat='{}{0} хв'}" FontFamily="Century Gothic"/>
                            </TextBlock>

                            <TextBlock FontSize="19" Margin="0,0,10,10" TextWrapping="Wrap">
                            <Run Text="Жанр: " FontWeight="Bold"/>                            
                            <Run x:Name="GenresText" FontFamily="Century Gothic"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                
                
                

                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0, 0, 20, 0">
                    <Border Background="#D6E0F5" CornerRadius="20">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontSize="32" FontFamily="Century Gothic" FontWeight="Bold" Margin="20,20,20,10"/>
                            <TextBlock Text="{Binding Description}" FontSize="20"  TextWrapping="Wrap" Margin="20,20,20,60"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#D6E0F5" CornerRadius="20" Margin="0, 20, 0, 0">



                        <StackPanel>
                            <TextBlock x:Name="cinemaNane" FontSize="32" FontWeight="Bold" Margin="25,20,10,10" TextWrapping="Wrap">
                                <Run Text="Доступні сеанси - Кінотеатр" FontFamily="Century Gothic" FontWeight="Bold"/>            
                                <Run Text="{Binding Name, StringFormat='{}{0}'}" FontFamily="Century Gothic"/>
                            </TextBlock>
                            <ItemsControl x:Name="SessionGrid" Margin="20">

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Session_Click">
                                            <Border Width="160" Height="45" Margin="10" CornerRadius="10" Background="#4A69BD" Cursor="Hand">

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding StartTime, StringFormat='{}{0:dd.MM.yyyy - HH:mm}'}" 
                                                Foreground="White" 
                                                FontWeight="SemiBold"
 
                                                FontSize="16" 
                                                HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>

                                                    <TextBlock x:Name="hallName" Text="{Binding Name, StringFormat='{}{0}'}" 
                                                Foreground="White" 
                                                FontWeight="SemiBold" 
                                                FontSize="16" 
                                                HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>
                                                    
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
