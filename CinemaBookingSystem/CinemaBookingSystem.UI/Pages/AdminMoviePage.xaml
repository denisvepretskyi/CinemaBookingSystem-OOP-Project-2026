<Page x:Class="CinemaBookingSystem.UI.Pages.AdminMoviePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="MoviesAdminPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="*"/>
            <!-- Таблиця (займає весь вільний простір) -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопка "Додати" -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Керування фільмами" FontFamily="Century Gothic" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- ТАБЛИЦЯ -->
        <DataGrid Grid.Row="1" x:Name="MoviesDataGrid" 
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False" 
                  HeadersVisibility="Column"
                  Background="Transparent"
                  BorderBrush="#DDDDDD"
                  BorderThickness="1"
                  RowHeight="40"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EEEEEE"
                  Margin="0,0,0,20">

            <DataGrid.Resources>
                <!-- Стиль для центрування тексту всередині клітинок -->
                <Style x:Key="CenterText" TargetType="TextBlock">
                    <Setter Property="HorizontalAlignment" Value="Center"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>

                <Style x:Key="VerticalCenterText" TargetType="TextBlock">
                    <Setter Property="VerticalAlignment" Value="Center"/>                    
                </Style>

            </DataGrid.Resources>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <!-- Центруємо самі заголовки колонок -->
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>

                    <!-- Якщо ви раніше робили заголовки жирними, залишаємо це -->
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="5"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <!-- Текстові колонки з прив'язкою до властивостей вашої моделі Movie -->
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" ElementStyle="{StaticResource CenterText}" Width="40" IsReadOnly="True"/>
                <DataGridTextColumn Header="Назва" Binding="{Binding Title}" ElementStyle="{StaticResource VerticalCenterText}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Режисер" Binding="{Binding Director}" ElementStyle="{StaticResource VerticalCenterText}"   Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="Тривалість" Binding="{Binding Duration}" ElementStyle="{StaticResource CenterText}" Width="85" IsReadOnly="True"/>

                <!-- Колонка з кнопками дій -->
                <DataGridTemplateColumn Header="Дії" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- Кнопка Редагувати -->
                                <Button Content="✏️" Width="30" Height="30" Margin="0,0,10,0" 
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" 
                                        ToolTip="Редагувати" Click="EditMovie_Click"/>

                                <!-- Кнопка Видалити -->
                                <Button Width="30" Height="30" 
                                        Background="Transparent" BorderThickness="0" Cursor="Hand" 
                                        ToolTip="Видалити" Click="DeleteMovie_Click">

                                    <Image Source="pack://application:,,,/Images/Delete.png" 
                                     Stretch="Uniform" Margin="8" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <Button Grid.Row="2"  HorizontalAlignment="Right" 
                Width="200" Height="45" Background="#4A69BD" FontWeight="SemiBold" 
                BorderThickness="0" Cursor="Hand" Click="AddMovie_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                        <TextBlock Text="Додати" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="16"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
            <Button.Style>
                <Style TargetType="Button">
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#B5BCCC"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Page>