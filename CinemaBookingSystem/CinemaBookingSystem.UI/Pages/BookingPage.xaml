<Page x:Class="CinemaBookingSystem.UI.Pages.BookingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaBookingSystem.UI.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BookingPage">

    

    <Grid>
        <Grid Margin="40, 20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" VerticalAlignment="Top"
            Background="#D6E0F5" 
            CornerRadius="20" 
            Margin="0,60,0,20">

                <StackPanel Margin="30">
                    <TextBlock  Text ="Інформація про сеанс" FontFamily="Century Gothic" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>                    
                    
                    <TextBlock x:Name="MovieTitleTextBlock" VerticalAlignment="Top"  FontSize="18" >
                        <Run Text="Назва фільму: " FontWeight="Bold"/>
                        <Run Text="{Binding Title, StringFormat='{}{0}'}" FontFamily="Century Gothic"/>  
                    </TextBlock>

                    <TextBlock FontSize="18">
                        <Run Text="Ціна квитка: " FontWeight="Bold"/>
                        <Run Text="{Binding Price,StringFormat='{}{0} грн.'}" FontFamily="Century Gothic"/>
                    </TextBlock>

                    <TextBlock FontSize="18">
                        <Run Text="Дата та час: " FontWeight="Bold"/>
                        <Run Text="{Binding StartTime, StringFormat='{}{0:dd.MM.yyyy - HH:mm}'}" FontFamily="Century Gothic"/>
                    </TextBlock>

                    <TextBlock x:Name="HallNameTextBlock" FontSize="18" Margin="0,20,0,0">
                        <Run Text="Зал: " FontWeight="Bold"/>
                        <Run Text="{Binding Name, StringFormat='{}{0}'}" FontFamily="Century Gothic"/>
                    </TextBlock>

                    <TextBlock x:Name="CinemaAddressTextBlock" FontSize="18">
                        <Run Text="Адреса: " FontWeight="Bold"/>
                        <Run Text="{Binding Address, StringFormat='{}{0}'}" FontFamily="Century Gothic"/>
                    </TextBlock>
                </StackPanel>

            </Border>

            <Border Grid.Row="1" Background="#FFC3CAD8"  CornerRadius="20">

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">


                    <StackPanel>
                        <TextBlock  Text ="Оберіть місце на схемі залу" FontFamily="Century Gothic" FontSize="24" FontWeight="Bold" Margin="30,30,0,40"/>
                        <Viewbox Grid.Row="1" Margin="0,10">
                            <ItemsControl x:Name="SeatsItemsControl" Margin="20,0,0,50" HorizontalAlignment="Center" VerticalAlignment="Center">

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="{Binding ColumnCount}"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Width="35" Height="35" Margin="4" 
                BorderThickness="0" Cursor="Hand"
                Click="SeatButton_Click">

                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#4A69BD"/>

                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#FF55565B"/>
                                                        </DataTrigger>

                                                        <DataTrigger Binding="{Binding IsTaken}" Value="True">
                                                            <Setter Property="Background" Value="#FF2B3E5B"/>
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                            <Setter Property="Cursor" Value="No"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Button.ToolTip>
                                                <TextBlock FontSize="14">
                    <Run Text="Ряд: " FontWeight="Bold"/>
                    <Run Text="{Binding Row}"/>
                    <Run Text=" | Місце: " FontWeight="Bold"/>
                    <Run Text="{Binding Column}"/>
                                                </TextBlock>
                                            </Button.ToolTip>

                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Viewbox>

                        <Button x:Name="ConfirmBookingButton"
                        Content="Підтвердити бронювання" FontFamily="Century Gothic" Foreground="#FFD3D8E8" FontSize="18" FontWeight="Bold"
                        VerticalAlignment="Bottom" Click="ConfirmOrder_Click" HorizontalAlignment="Right" 
                        Height="50" Width="260" Margin="0,0,30,10" BorderThickness="0">

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#FF55565B"/>
                                    <Setter Property="IsEnabled" Value="False"/>

                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                                            <Setter Property="Background" Value="#4A69BD"/>
                                            <Setter Property="IsEnabled" Value="True"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>


                    </StackPanel>
                </ScrollViewer>
            </Border>
            
        </Grid>
    </Grid>
</Page>
