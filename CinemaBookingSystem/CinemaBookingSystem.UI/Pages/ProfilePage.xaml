<Page x:Class="CinemaBookingSystem.UI.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CinemaBookingSystem.UI.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ProfilePage">

        <Grid Margin="40, 20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" VerticalAlignment="Top" Background="#D6E0F5" CornerRadius="20" Margin="0,60,0,20">
                <StackPanel Margin="30">
                    <TextBlock Text="Особистий кабінет" FontFamily="Century Gothic" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

                    <TextBlock Text="Ім'я:" FontFamily="Century Gothic" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="NameTextBox" Height="35" Margin="0,0,0,15" BorderThickness="0" Padding="10,5" Background="White" FontFamily="Century Gothic"/>

                    <TextBlock Text="Номер телефону:" FontFamily="Century Gothic" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="PhoneTextBox" Height="35" Margin="0,0,0,15" BorderThickness="0" Padding="10,5" Background="White" FontFamily="Century Gothic"/>

                    <TextBlock Text="Пароль:" FontFamily="Century Gothic" FontSize="14" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox" Height="35" Margin="0,0,0,20" BorderThickness="0" Padding="10,5" Background="White"/>

                    <Grid>
                        <Button Grid.Column="0" x:Name="SaveButton" Content="Зберегти зміни" Height="40" Width="180" 
                HorizontalAlignment="Left" Background="#4A69BD" Foreground="White" 
                BorderThickness="0" Cursor="Hand" Click="SaveButton_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="1" x:Name="LogoutButton" Content="Вихід" Height="40" Width="180" 
                HorizontalAlignment="Right" Background="#4A69BD" Foreground="White" 
                BorderThickness="0" Cursor="Hand" Click="Logout_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </Button.Resources>
                        </Button>


                    </Grid>

                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#FFC3CAD8"  CornerRadius="20">

                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Border Grid.Row="1" Background="#FFC3CAD8" CornerRadius="20">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="30">
                                <TextBlock Text="Мої квитки" FontFamily="Century Gothic" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                                <Grid Margin="10,0,10,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Назва фільму" FontWeight="Bold" Foreground="#555555"/>
                                    <TextBlock Grid.Column="1" Text="Кінотеатр" FontWeight="Bold" Foreground="#555555"/>
                                    <TextBlock Grid.Column="2" Text="Час проведення" FontWeight="Bold" Foreground="#555555"/>
                                    <TextBlock Grid.Column="3" Text="Місце" FontWeight="Bold" Foreground="#555555"/>
                                </Grid>

                                <ItemsControl x:Name="TicketsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="10" Margin="0,0,0,10" Padding="10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2.5*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="120"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding MovieTitle}" 
                               VerticalAlignment="Center" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,10,0"/>

                                                    <TextBlock Grid.Column="1" Text="{Binding CinemaName}" 
                               VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,10,0"/>

                                                    <TextBlock Grid.Column="2" Text="{Binding StartTime, StringFormat='{}{0:dd.MM.yyyy - HH:mm}'}" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>

                                                    <TextBlock Grid.Column="3" VerticalAlignment="Center">
                        <Run Text="Ряд " Foreground="#666666"/>
                        <Run Text="{Binding Row}" FontWeight="Bold"/>
                        <Run Text=", міс. " Foreground="#666666"/>
                        <Run Text="{Binding Column}" FontWeight="Bold"/>
                                                    </TextBlock>

                                                    <Button Grid.Column="4" Content="Повернути" 
                            Height="35" Background="#FF676C7F" Foreground="White" 
                            BorderThickness="0" Cursor="Hand" Click="ReturnTicket_Click">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#FFD9534F"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </ScrollViewer>
            </Border>
        </Grid>
</Page>
