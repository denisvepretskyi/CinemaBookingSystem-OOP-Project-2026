        {
            MovieEditWindow window = new MovieEditWindow();
            window.Show();
 
        }

        // 2. Обробник кнопки "Редагувати" (всередині DataGrid)
        private void EditMovie_Click(object sender, RoutedEventArgs e)
        {
            if (sender is Button button && button.DataContext is Movie selectedMovie)
            {
                MovieEditWindow window = new MovieEditWindow(selectedMovie);
                window.Show();
            }
        }

